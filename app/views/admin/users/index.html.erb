<h1 class="text-2xl mb-4">Users</h1>

<table class="min-w-full border">
  <thead>
    <tr>
      <th class="border px-2 py-1 text-left">Email</th>
      <th class="border px-2 py-1 text-left">Role</th>
      <th class="border px-2 py-1 text-left">Action</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td class="border px-2 py-1"><%= user.email %></td>
        <td class="border px-2 py-1">
          <%= form_with model: [:admin, user], local: true do |f| %>
            <%= f.select :role, User::ROLES.values, selected: user.role %>
        </td>
        <td class="border px-2 py-1">
            <%= f.submit "Update", class: "border px-2 py-1" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
